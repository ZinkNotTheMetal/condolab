# Copy this file to .env before starting the stack.
# Do not commit the real .env file.

# Required platform encryption key. 
# Generate with: openssl rand -hex 16
ENCRYPTION_KEY=replace-with-generated-32-char-hex-key

# Required JWT signing secret. 
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-generated-auth-secret

# Postgres
POSTGRES_USER=infisical
# Postgres password. 
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=replace-with-generated-postgres-password
POSTGRES_DB=infisical

# Internal service connections
DB_CONNECTION_URI=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
REDIS_URL=redis://redis:6379

# Site URL for the Traefik-routed Infisical hostname.
SITE_URL=https://infisical.home.arpa

# Optional SMTP
SMTP_HOST=
SMTP_PORT=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=Infisical
SMTP_USERNAME=
SMTP_PASSWORD=

# Optional telemetry
OTEL_TELEMETRY_COLLECTION_ENABLED=false
OTEL_EXPORT_TYPE=prometheus
