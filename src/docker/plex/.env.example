# Copy to .env before starting the stack.
# Do not commit the real .env file.

PUID=1000
PGID=1000
TZ=America/Chicago

# Optional one-time claim token used during initial server registration.
# Get from: https://www.plex.tv/claim/
PLEX_CLAIM=

# Keep the friendly HTTPS endpoint first so Plex clients prefer it.
ADVERTISE_IP=https://plex.zinkzone.tech
