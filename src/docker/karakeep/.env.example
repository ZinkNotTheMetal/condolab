# Copy this file to .env before starting the stack.
# Do not commit the real .env file.

# Routed application URL.
NEXTAUTH_URL=https://karakeep.zinkzone.tech

# Generate with: openssl rand -base64 36
NEXTAUTH_SECRET=replace-with-generated-nextauth-secret

# Generate with: openssl rand -base64 36 | tr -dc 'A-Za-z0-9'
MEILI_MASTER_KEY=replace-with-generated-meili-master-key

# Optional application tuning.
LOG_LEVEL=info
DB_WAL_MODE=true

# Local Ollama inference.
INFERENCE_TEXT_MODEL=qwen2.5:3b
OLLAMA_KEEP_ALIVE=10m
INFERENCE_ENABLE_AUTO_TAGGING=true
INFERENCE_ENABLE_AUTO_SUMMARIZATION=false
INFERENCE_JOB_TIMEOUT_SEC=120
INFERENCE_FETCH_TIMEOUT_SEC=600

# Optional crawler and OCR tuning.
CRAWLER_NUM_WORKERS=1
OCR_LANGS=eng
