# Copy to .env before starting the stack.
# Do not commit the real .env file.

PUID=1000
PGID=1000
TZ=America/Chicago
PIA_OPENVPN_USER=replace-with-pia-username
PIA_OPENVPN_PASSWORD=replace-with-pia-password
PIA_SERVER_REGIONS=US East
GLUETUN_FIREWALL_OUTBOUND_SUBNETS=192.168.0.0/24,192.168.200.0/24
GLUETUN_HEALTH_TARGET_ADDRESS=1.1.1.1:443
GLUETUN_LOG_LEVEL=info
